import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv("social_media_engagement1.csv")

df.head()

df['engagement'] = df['likes'] + df['comments'] + df['shares']

df['post_time'] = pd.to_datetime(df['post_time'])

df['hour'] = df['post_time'].dt.hour

engagement_post_type = df.groupby('post_type')['engagement'].mean().sort_values(ascending=False)

engagement_post_type.plot(kind='bar')
plt.title("Average Engagement by Post Type")
plt.show()

#Polls and videos generate the highest engagement.
#Interactive content tends to perform better.

pivot = df.pivot_table(
    values='engagement',
    index='post_type',
    columns='platform',
    aggfunc='mean'
)

pivot.plot(kind='bar')
plt.title("Engagement by Platform and Post Type")
plt.show()

#Instagram performs best for visual content.
#Facebook performs best for polls.

pivot = df.pivot_table(
    values='engagement',
    index='post_day',
    columns='hour',
    aggfunc='mean'
)

sns.heatmap(pivot)
plt.title("Engagement by Day and Hour")
plt.show()
